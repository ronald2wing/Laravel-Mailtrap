{
    "name": "ronald2wing/laravel-mailtrap",
    "description": "Laravel mail transport for the Mailtrap Email Sending API",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "email",
        "laravel",
        "mailtrap",
        "transport"
    ],
    "authors": [
        {
            "name": "Ronald Wong",
            "email": "ronald2wing@gmail.com",
            "homepage": "https://github.com/ronald2wing",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/mail": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ronald2Wing\\LaravelMailtrap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ronald2Wing\\LaravelMailtrap\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "support": {
        "issues": "https://github.com/ronald2wing/laravel-mailtrap/issues",
        "source": "https://github.com/ronald2wing/laravel-mailtrap",
        "forum": "https://github.com/ronald2wing/laravel-mailtrap/discussions"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ronald2wing"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Ronald2Wing\\LaravelMailtrap\\MailtrapServiceProvider"
            ]
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "test": "vendor/bin/phpunit --coverage-clover coverage/clover.xml --coverage-html coverage",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}
